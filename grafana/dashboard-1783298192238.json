                        "queryType": "table",
                        "rawSql": "SELECT\r\n    category,\r\n    MAX(if(source = 'ФГОС', 1, 0)) AS in_fgos,\r\n    MAX(if(source = 'Профстандарт', 1, 0)) AS in_prof,\r\n    MAX(if(source = 'Вакансия', 1, 0)) AS in_vac\r\nFROM competencies_olap\r\nGROUP BY category\r\nHAVING in_fgos + in_prof + in_vac > 0\r\nORDER BY category"
